# Normalize text files and pin LF endings for source / config.
# Prevents noisy CRLF/LF churn when collaborators commit from Windows.
* text=auto eol=lf

# Source code
*.go    text eol=lf
*.sql   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Always-binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
